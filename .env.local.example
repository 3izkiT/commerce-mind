# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Money Space Payment Gateway
# secretId and secretKey from MoneySpace merchant dashboard
MONEYSPACE_API_KEY=your_moneyspace_secret_id
MONEYSPACE_SECRET=your_moneyspace_secret_key

# Upstash Redis (rate limiting: 1 free generation per IP per 24h)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
